# ===========================================
# Invoice Server Environment Configuration
# ===========================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://invoice_user:your_secure_password@localhost:5432/invoice_db

# Tax Portal Credentials
# Add multiple companies as TAX_COMPANY_1, TAX_COMPANY_2, etc.
TAX_USERNAME=0202180901
TAX_PASSWORD=your_password_here

# Collector Schedule (hours between runs)
COLLECTOR_INTERVAL_HOURS=6

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_this_to_a_random_secret_key

# JWT Authentication
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Telegram Bot Notifications (optional)
# Create a bot via @BotFather on Telegram to get the token
# Send a message to your bot, then get chat_id from: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Environment
ENV=development
DEBUG=true
